---
import Layout from '../components/Layout.astro';

const themes = [
  {
    number: '01',
    title: 'Hub Airports & Network Disruption',
    questions: [
      'How do hub airports absorb or amplify disruption?',
      'How does network concentration affect recovery?',
    ],
  },
  {
    number: '02',
    title: 'Regional Airports & Accessibility',
    questions: [
      'Why do regional airports experience delays differently?',
      'How do limited route options affect reliability?',
    ],
  },
  {
    number: '03',
    title: 'Delay Propagation & Resilience',
    questions: [
      'How do delays move through airline networks?',
      'What makes an aviation network resilient?',
    ],
  },
];

const methods = [
  'Data Analysis',
  'Statistical Modeling',
  'Network Analysis',
  'Interactive Visualization',
];

const futureDirections = [
  'Live route-risk evaluation',
  'Delay propagation visualization',
  'Hub vs regional airport comparison',
  'Aviation network resilience metrics',
];
---

<Layout
  title="Research"
  description="Hexin Yu's research agenda on aviation systems, hub airports, regional accessibility, delay propagation, and network resilience."
>
  <div class="research-page">
    <section class="research-hero">
      <div class="container research-hero-grid">
        <div>
          <p class="page-kicker">Research</p>
          <h1>Research Agenda</h1>
          <p class="hero-subtitle">I study aviation systems through data, geography, and network thinking.</p>
          <p class="lead">
            My work asks how flight disruptions begin, how they propagate through hub-and-spoke networks, and how
            visual analytics can make transportation systems easier to understand.
          </p>
        </div>
        <aside class="agenda-note" aria-label="Research framing note">
          <span>Working Frame</span>
          <p>
            Aviation reliability is not only an operational question. It is also geographic: routes, hubs, regional
            access, and recovery options shape how disruption is experienced.
          </p>
        </aside>
      </div>
    </section>

    <section class="container agenda-section" aria-labelledby="themes-heading">
      <div class="section-heading">
        <div>
          <p class="page-kicker">Research Themes</p>
          <h2 id="themes-heading">Questions that organize the work</h2>
        </div>
      </div>

      <div class="theme-grid">
        {themes.map((theme) => (
          <article class="theme-card">
            <p class="theme-number">{theme.number}</p>
            <h3>{theme.title}</h3>
            <ul>
              {theme.questions.map((question) => <li>{question}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="methods-band" aria-labelledby="methods-heading">
      <div class="container methods-layout">
        <div>
          <p class="page-kicker">Methods / Tools</p>
          <h2 id="methods-heading">Analytical toolkit</h2>
          <p>
            I use data analysis, statistical modeling, network analysis, and interactive visualization to connect
            aviation datasets with interpretable research questions.
          </p>
        </div>
        <div class="method-tags">
          {methods.map((method) => <span>{method}</span>)}
        </div>
      </div>
    </section>

    <section class="container agenda-section future-section" aria-labelledby="future-heading">
      <div class="section-heading">
        <div>
          <p class="page-kicker">Future Directions</p>
          <h2 id="future-heading">Next research directions</h2>
        </div>
      </div>
      <ul class="future-grid">
        {futureDirections.map((direction) => (
          <li>
            <span aria-hidden="true"></span>
            {direction}
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>

<style>
  .research-page {
    padding-bottom: 88px;
  }

  .research-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(circle at 82% 12%, rgba(245, 158, 11, 0.18), transparent 28%),
      radial-gradient(circle at 12% 88%, rgba(37, 99, 235, 0.1), transparent 34%),
      linear-gradient(135deg, #fffdf8 0%, #fff7ed 52%, #ffffff 100%);
    padding: 86px 0 74px;
  }

  .research-hero::after {
    position: absolute;
    inset: auto 0 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(245, 158, 11, 0.48), transparent);
    content: '';
  }

  .research-hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: 52px;
    align-items: end;
  }

  .research-hero h1 {
    font-size: clamp(3rem, 7vw, 6rem);
  }

  .hero-subtitle {
    max-width: 760px;
    margin-top: 18px;
    color: var(--accent-dark);
    font-size: clamp(1.2rem, 2.3vw, 1.7rem);
    font-weight: 720;
    line-height: 1.38;
  }

  .agenda-note {
    border: 1px solid rgba(245, 158, 11, 0.24);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(255, 248, 235, 0.94)),
      #fff;
    box-shadow: 0 22px 52px rgba(63, 47, 31, 0.08);
    padding: 24px;
  }

  .agenda-note span {
    display: inline-flex;
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 4px 10px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .agenda-note p {
    margin-top: 16px;
    color: var(--muted);
  }

  .agenda-section {
    padding-top: 68px;
  }

  .theme-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
  }

  .theme-card {
    display: grid;
    align-content: start;
    min-height: 360px;
    border: 1px solid var(--border);
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(245, 158, 11, 0.07), transparent 48%),
      #ffffff;
    box-shadow: 0 14px 34px rgba(63, 47, 31, 0.06);
    padding: 28px;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .theme-card:hover {
    border-color: rgba(245, 158, 11, 0.42);
    background:
      linear-gradient(180deg, rgba(245, 158, 11, 0.12), transparent 52%),
      #ffffff;
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .theme-number {
    display: inline-flex;
    width: fit-content;
    border: 1px solid rgba(245, 158, 11, 0.32);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 4px 10px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .theme-card h3 {
    margin-top: 18px;
    font-size: clamp(1.35rem, 2vw, 1.65rem);
  }

  .theme-card ul {
    display: grid;
    gap: 13px;
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
  }

  .theme-card li {
    position: relative;
    padding-left: 20px;
    color: var(--muted);
  }

  .theme-card li::before {
    position: absolute;
    top: 0.72em;
    left: 0;
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--gold);
    content: '';
  }

  .methods-band {
    margin-top: 72px;
    border-block: 1px solid var(--border);
    background:
      linear-gradient(90deg, rgba(245, 158, 11, 0.08) 1px, transparent 1px),
      linear-gradient(180deg, #fff8eb 0%, #fffdf8 100%);
    background-size: 42px 42px, auto;
    padding: 56px 0;
  }

  .methods-layout {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .methods-layout p:last-child {
    margin-top: 14px;
    color: var(--muted);
  }

  .method-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .method-tags span {
    border: 1px solid var(--border);
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 10px 24px rgba(63, 47, 31, 0.045);
    color: var(--warm-ink);
    padding: 10px 14px;
    font-size: 0.95rem;
    font-weight: 720;
  }

  .future-section {
    padding-top: 64px;
  }

  .future-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .future-grid li {
    display: grid;
    gap: 18px;
    min-height: 150px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background: #fff;
    box-shadow: 0 10px 24px rgba(63, 47, 31, 0.045);
    padding: 18px;
    color: var(--text);
    font-weight: 680;
  }

  .future-grid span {
    width: 28px;
    height: 3px;
    border-radius: 999px;
    background: var(--gold);
  }

  @media (max-width: 980px) {
    .research-hero-grid,
    .methods-layout {
      grid-template-columns: 1fr;
    }

    .theme-grid {
      grid-template-columns: 1fr;
    }

    .theme-card {
      min-height: auto;
    }

    .future-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .research-page {
      padding-bottom: 62px;
    }

    .research-hero {
      padding: 60px 0 52px;
    }

    .agenda-section,
    .future-section {
      padding-top: 44px;
    }

    .theme-card,
    .agenda-note {
      border-radius: 20px;
      padding: 22px;
    }

    .methods-band {
      margin-top: 48px;
      padding: 44px 0;
    }

    .future-grid {
      grid-template-columns: 1fr;
    }

    .future-grid li {
      min-height: auto;
    }
  }
</style>
