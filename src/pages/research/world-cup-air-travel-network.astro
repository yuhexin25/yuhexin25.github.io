  .article-grid{display:grid;grid-template-columns:190px minmax(0,820px);gap:64px;justify-content:center;padding-block:76px 110px}.article-aside{position:sticky;top:110px;align-self:start}.article-aside>p,.eyebrow{margin-bottom:13px;color:var(--gold-dark);font-size:.75rem!important;font-weight:800;letter-spacing:.1em;text-transform:uppercase}.tags{display:flex;flex-wrap:wrap;gap:8px}.tags span{border:1px solid var(--border);border-radius:999px;background:#fff;padding:5px 9px;color:#5f564b;font-size:.74rem}.prose section+section{margin-top:58px}.prose h2{margin-bottom:22px;font-size:clamp(1.7rem,3vw,2.35rem)}.prose p{color:#374151;font-family:Georgia,'Times New Roman',serif;font-size:1.08rem;line-height:1.88}.prose p+p{margin-top:20px}.standfirst{border-left:4px solid var(--gold);padding-left:22px;color:#1e293b!important;font-size:1.28rem!important;line-height:1.65!important}.method-box{border:1px solid #e8c98e;border-radius:22px;background:#fff9ed;padding:30px}.method-box ul{display:grid;gap:13px;margin:0;padding-left:20px;color:#4b5563}.source-note{margin-top:20px!important;color:#6b5f4e!important;font-family:inherit!important;font-size:.82rem!important}.source-note code{font-size:.78rem}
