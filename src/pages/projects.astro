---
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projectsByYear } from '../data/projects';

const years = Object.keys(projectsByYear).sort((a, b) => Number(b) - Number(a));
---

<Layout
  title="Projects"
  description="Projects by Hexin Yu on aviation networks, flight disruptions, transportation systems, GIS, and data visualization."
>
  <div class="page-shell">
    <header class="container page-intro projects-intro">
      <p class="page-kicker">Projects</p>
      <h1>Curated project archive</h1>
      <p class="lead">
        Each project is a working answer to one question: how can data help us understand aviation networks,
        flight disruptions, and transportation systems?
      </p>
    </header>

    <div class="container year-groups">
      {years.map((year) => (
        <section class="year-group" aria-labelledby={`year-${year}`}>
          <h2 id={`year-${year}`}>{year}</h2>
          <div>
            {projectsByYear[year].map((project) => <ProjectCard {...project} />)}
          </div>
        </section>
      ))}
    </div>
  </div>
</Layout>

<style>
  .year-groups {
    display: grid;
    gap: 48px;
  }

  .year-group {
    display: grid;
    grid-template-columns: 110px minmax(0, 1fr);
    gap: 30px;
    border: 1px solid var(--border);
    border-radius: 22px;
    background: var(--paper);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.055);
    padding: 26px;
  }

  .year-group h2 {
    color: var(--accent);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 1.05rem;
    font-weight: 760;
  }

  .year-group :global(.project-year) {
    display: none;
  }

  .year-group :global(.project-card:first-child) {
    border-top: 0;
    padding-top: 0;
  }

  .year-group :global(.project-card:last-child) {
    padding-bottom: 0;
  }

  @media (max-width: 760px) {
    .year-group {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 20px;
    }
  }
</style>
