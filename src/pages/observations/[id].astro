---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { formatDate } from '../../utils/formatDate';

export async function getStaticPaths() {
  const observations = await getCollection('observations');
  return observations.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="page-shell">
    <div class="container observation">
      <a class="back-link" href={`${import.meta.env.BASE_URL}observations`}>Research Notes -></a>
      <p class="page-kicker">Research note</p>
      <h1>{post.data.title}</h1>
      <p class="meta">
        {formatDate(post.data.pubDate)}
      </p>
      <div class="tag-row">
        {post.data.tags.map((tag) => <span>{tag}</span>)}
      </div>
      <div class="content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .observation {
    max-width: 820px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 36px;
  }

  .observation h1 {
    font-size: clamp(2.1rem, 4.8vw, 4rem);
  }

  .content {
    margin-top: 34px;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }

  .content :global(p) {
    margin: 0 0 18px;
    color: #303942;
  }

  .content :global(h2) {
    margin: 32px 0 12px;
  }
</style>
