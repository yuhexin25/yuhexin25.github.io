---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';
import { formatDate } from '../../utils/formatDate';

const observations = (await getCollection('observations'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Research Notes"
  description="Research notes by Hexin Yu on aviation networks, delay prediction, hub airports, and geographic data visualization."
>
  <div class="page-shell">
    <header class="container page-intro">
      <p class="page-kicker">Research Notes</p>
      <h1>Short notes on aviation data and geographic systems</h1>
      <p class="lead">
        These are compact research notes on airport networks, delay prediction, geographic systems, and the small
        analytical decisions that shape aviation dashboards.
      </p>
    </header>

    <section class="container">
      <ul class="note-list observations-list">
        {observations.map((post) => (
          <li>
            <a href={`${import.meta.env.BASE_URL}observations/${post.id}`}>{post.data.title}</a>
            <p class="meta">
              {formatDate(post.data.pubDate)}
            </p>
            <p>{post.data.description}</p>
            <div class="tag-row">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </li>
        ))}
      </ul>
    </section>
  </div>
</Layout>

<style>
  .observations-list p:not(.meta) {
    max-width: 760px;
    margin-top: 6px;
    color: var(--muted);
  }

  .observations-list li {
    border-radius: 16px;
    padding-inline: 18px;
    transition:
      background 160ms ease,
      transform 160ms ease;
  }

  .observations-list li:hover {
    background: #fff;
    transform: translateX(4px);
  }
</style>
