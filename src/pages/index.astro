---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';

const base = import.meta.env.BASE_URL;
const featuredProjects = [
  {
    number: '01',
    title: 'U.S. Airline Hub Atlas',
    type: 'Interactive Map',
    description: 'Interactive visualization of U.S. airline hub structures and connectivity patterns.',
    researchQuestion: 'How do hub-and-spoke structures shape airline connectivity?',
    methods: 'Network analysis, MapLibre, D3',
    data: 'FAA, BTS, airline route data',
    href: 'https://yuhexin25-oss.github.io/us-airline-hub-atlas/',
    image: `${base}project-previews/hub-atlas.svg`,
    imageAlt: 'Route map preview of the U.S. Airline Hub Atlas.',
    external: true,
  },
  {
    number: '02',
    title: 'Live Flight Delay Analysis',
    type: 'Live Dashboard',
    description: 'Real-time aviation delay monitoring and route risk assessment using FAA and aviation data.',
    researchQuestion: 'How do real-time disruptions affect airport and route reliability?',
    methods: 'API integration, dashboard design, delay risk scoring',
    data: 'FAA, FlightAware and public aviation sources',
    href: 'https://yuhexin25-oss.github.io/livedelayanalysis/',
    image: `${base}project-previews/route-risk.svg`,
    imageAlt: 'Live flight delay and route risk dashboard preview.',
    external: true,
  },
  {
    number: '03',
    title: 'World Cup Air Travel Network',
    type: 'Research Article',
    description: 'Analysis of fan mobility and airline network responses during FIFA World Cup 2026.',
    researchQuestion: 'How do major sporting events reshape international air mobility?',
    methods: 'GIS, network visualization, comparative case analysis',
    data: 'FIFA host cities, airline networks, public aviation sources',
    href: `${base}blog/hubs-alliances-world-cup-mobility/`,
    image: `${base}blog/hubs-alliances-world-cup-mobility-hero.png`,
    imageAlt: 'North American airline hub network created for the World Cup aviation analysis.',
    external: false,
  },
];
const readingNotes = (await getCollection('reading-notes')).sort(
  (a, b) => `${a.data.source.name} ${a.data.title}`.localeCompare(`${b.data.source.name} ${b.data.title}`),
);
const featuredLibraryNote = readingNotes[0];
const featuredLibraryHref = featuredLibraryNote
  ? `${base}reading-notes/${featuredLibraryNote.data.source.slug}/${featuredLibraryNote.data.noteSlug}`
  : `${base}reading-notes`;
const featuredBlogArticle = {
  title: 'World Cup 2026 and the U.S. Aviation System',
  description:
    'Demand waves, summer thunderstorms, and what I observed while traveling through Houston during consecutive matchdays.',
  href: `${base}blog/world-cup-us-aviation-system/`,
  image: `${base}research/houston-match-attendance.jpg`,
  meta: 'June 20, 2026 / 7 min read',
};
const currentProjects = [
  { title: 'Live Flight Delay Analysis', status: 'Active development', tone: 'active' },
  { title: 'World Cup Air Travel Network', status: 'Writing and visualization', tone: 'progress' },
  { title: 'Hub vs Regional Airport Study', status: 'Planned analysis', tone: 'planned' },
];
---

<Layout
  title="Aviation Analytics Portfolio"
  description="Hexin Yu is a Virginia Tech Computational Modeling & Data Analytics student interested in aviation analytics, transportation systems, data visualization, and network analysis."
>
  <section class="hero-section" aria-labelledby="home-title">
    <svg class="route-field" viewBox="0 0 1200 520" aria-hidden="true">
      <path d="M-30 400 C 210 260, 370 270, 610 130 S 1000 50, 1240 180" />
      <path d="M80 120 C 300 210, 420 92, 640 220 S 960 390, 1210 300" />
      <path d="M220 510 C 380 380, 520 390, 720 310 S 980 210, 1180 250" />
      <circle cx="180" cy="318" r="5" />
      <circle cx="610" cy="130" r="5" />
      <circle cx="890" cy="92" r="5" />
      <circle cx="1030" cy="342" r="5" />
    </svg>
    <div class="container priority-grid">
      <div class="hero-copy">
        <h1 id="home-title">Hexin Yu</h1>
        <p class="hero-subtitle">Computational Modeling & Data Analytics Student<br />Virginia Tech</p>
        <p class="gpa-line">GPA: 4.0/4.0</p>
        <p class="lead">
          I build data-driven tools for aviation networks, airport connectivity, and transportation systems.
        </p>
        <div class="button-row">
          <a class="button" href={`${base}projects`}>View Projects</a>
          <a class="button secondary" href={`${base}Hexin-Yu-CV.pdf`} target="_blank" rel="noopener noreferrer">Download CV</a>
        </div>
      </div>
      <section class="featured-projects" aria-labelledby="featured-projects-heading">
        <div class="featured-projects-heading">
          <h2 id="featured-projects-heading">Selected Work</h2>
          <a href={`${base}projects`}>All projects <span aria-hidden="true">→</span></a>
        </div>
        <div class="featured-project-list">
          {featuredProjects.map((project) => (
            <article class="priority-project-card">
              <img src={project.image} alt={project.imageAlt} />
              <div class="priority-project-copy">
                <div class="project-eyebrow"><span>{project.number}</span><b>{project.type}</b></div>
                <h3>{project.title}</h3>
                <dl class="priority-research-meta">
                  <div><dt>Research Question</dt><dd>{project.researchQuestion}</dd></div>
                  <div><dt>Methods</dt><dd>{project.methods}</dd></div>
                  <div><dt>Data</dt><dd>{project.data}</dd></div>
                </dl>
              </div>
              <a
                class="view-project"
                href={project.href}
                target={project.external ? '_blank' : undefined}
                rel={project.external ? 'noopener noreferrer' : undefined}
              >View project <span aria-hidden="true">↗</span></a>
            </article>
          ))}
        </div>
      </section>
    </div>
  </section>

  <div class="page-shell home-shell">
    <section class="section current-projects-section" aria-labelledby="current-projects-heading">
      <div class="container current-projects-layout">
        <div>
          <p class="page-kicker">In Progress</p>
          <h2 id="current-projects-heading">Current Projects</h2>
        </div>
        <div class="current-project-list">
          {currentProjects.map((project) => (
            <article>
              <span class:list={['current-status', `current-${project.tone}`]} aria-hidden="true"></span>
              <div><h3>{project.title}</h3><p>{project.status}</p></div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section research-interests-section" aria-labelledby="research-interests-heading">
      <div class="container research-interests-card">
        <div>
          <p class="page-kicker">Academic Focus</p>
          <h2 id="research-interests-heading">Research Interests</h2>
          <p>Computational Modeling &amp; Data Analytics student at Virginia Tech.</p>
        </div>
        <ul class="research-interest-list">
          <li>Airline Networks</li>
          <li>Transportation Analytics</li>
          <li>Aviation Reliability</li>
          <li>Data Visualization</li>
          <li>GIS</li>
        </ul>
      </div>
    </section>

    <section class="section featured-research-section" aria-labelledby="featured-research-heading">
      <div class="container section-heading">
        <h2 id="featured-research-heading">Latest Writing</h2>
        <a href={`${base}blog/`}>All posts -&gt;</a>
      </div>
      <a class="featured-research-card container" href={featuredBlogArticle.href}>
        <div class="featured-research-image">
          <img
            src={featuredBlogArticle.image}
            alt="Germany versus Curaçao scoreboard in Houston showing attendance of 68,021"
            loading="lazy"
          />
        </div>
        <div class="featured-research-copy">
          <p class="featured-research-meta">{featuredBlogArticle.meta}</p>
          <h3>{featuredBlogArticle.title}</h3>
          <p>{featuredBlogArticle.description}</p>
          <span>Read the article -&gt;</span>
        </div>
      </a>
    </section>

    {featuredLibraryNote && (
      <section class="section research-notes-section" aria-labelledby="research-notes-heading">
        <div class="container reading-strip">
          <div>
            <p class="page-kicker" id="research-notes-heading">Research Notes</p>
            <h2>
              <a href={featuredLibraryHref}>{featuredLibraryNote.data.title}</a>
            </h2>
            <p>{featuredLibraryNote.data.description}</p>
          </div>
          <div class="reading-meta">
            <span>{featuredLibraryNote.data.source.name}</span>
            <a class="text-link" href={`${base}reading-notes`}>Open library -></a>
          </div>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(circle at 78% 18%, rgba(245, 158, 11, 0.2), transparent 30%),
      radial-gradient(circle at 16% 78%, rgba(37, 99, 235, 0.13), transparent 34%),
      linear-gradient(135deg, #fffdf8 0%, #fff7ed 48%, #eff6ff 100%);
    background-size: auto, 46px 46px, auto;
    padding: 46px 0 50px;
  }

  .route-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.5;
    pointer-events: none;
  }

  .route-field path {
    fill: none;
    stroke: rgba(180, 83, 9, 0.18);
    stroke-width: 1.4;
  }

  .route-field circle {
    fill: var(--gold);
    filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.38));
  }

  .priority-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(340px, 0.78fr) minmax(520px, 1.22fr);
    gap: clamp(36px, 5vw, 74px);
    align-items: center;
  }

  .hero-copy {
    max-width: 580px;
  }

  .hero-copy .page-kicker {
    color: var(--gold-dark);
  }

  .hero-copy h1 {
    margin-top: 4px;
    color: var(--text);
    font-size: clamp(3.2rem, 6vw, 5.6rem);
    text-shadow: 0 18px 54px rgba(245, 158, 11, 0.12);
  }

  .hero-copy .lead {
    max-width: 560px;
    margin-top: 20px;
    color: #475569;
    font-size: clamp(1rem, 1.45vw, 1.16rem);
    line-height: 1.65;
  }

  .hero-subtitle {
    margin-top: 8px;
    color: var(--accent-dark);
    font-size: clamp(1rem, 1.7vw, 1.2rem);
    font-weight: 760;
    line-height: 1.45;
  }

  .gpa-line {
    width: fit-content;
    margin-top: 12px;
    border: 1px solid rgba(245, 158, 11, 0.32);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.7);
    color: var(--gold-dark);
    padding: 5px 11px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.8rem;
    font-weight: 800;
  }

  .hero-copy .button-row {
    margin-top: 24px;
  }

  .featured-projects {
    min-width: 0;
    border-left: 1px solid rgba(180, 83, 9, 0.18);
    padding-left: clamp(28px, 4vw, 50px);
  }

  .featured-projects-heading {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: end;
    margin-bottom: 14px;
  }

  .featured-projects-heading h2 {
    font-size: clamp(1.8rem, 3vw, 2.65rem);
  }

  .featured-projects-heading > a {
    flex: 0 0 auto;
    margin-bottom: 5px;
    color: var(--gold-dark);
    font-size: 0.86rem;
    font-weight: 760;
  }

  .featured-project-list {
    display: grid;
    gap: 10px;
  }

  .priority-project-card {
    display: grid;
    grid-template-columns: 128px minmax(0, 1fr) 102px;
    gap: 16px;
    align-items: center;
    overflow: hidden;
    min-height: 146px;
    border: 1px solid rgba(217, 206, 191, 0.92);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 12px 28px rgba(63, 47, 31, 0.07);
    color: var(--text);
    padding: 9px 14px 9px 9px;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .priority-project-card:hover {
    border-color: rgba(245, 158, 11, 0.48);
    box-shadow: 0 17px 34px rgba(63, 47, 31, 0.12);
    color: var(--text);
    text-decoration: none;
    transform: translateY(-2px);
  }

  .priority-project-card img {
    width: 128px;
    height: 128px;
    border-radius: 12px;
    object-fit: cover;
  }

  .priority-project-copy {
    min-width: 0;
  }

  .project-eyebrow {
    display: flex;
    flex-wrap: wrap;
    gap: 5px 9px;
    align-items: center;
  }

  .project-eyebrow span {
    color: var(--gold-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.7rem;
    font-weight: 800;
  }

  .project-eyebrow b {
    color: #64748b;
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .priority-project-card h3 {
    margin-top: 2px;
    font-size: clamp(1.02rem, 1.5vw, 1.22rem);
  }

  .priority-research-meta {
    display: grid;
    gap: 2px;
    margin: 5px 0 0;
  }

  .priority-research-meta div {
    display: grid;
    grid-template-columns: 86px minmax(0, 1fr);
    gap: 7px;
  }

  .priority-research-meta dt {
    color: var(--gold-dark);
    font-size: 0.59rem;
    font-weight: 820;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .priority-research-meta dd {
    min-width: 0;
    margin: 0;
    color: #5b6878;
    font-size: 0.67rem;
    line-height: 1.35;
  }

  .view-project {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    min-height: 34px;
    border: 1px solid rgba(245, 158, 11, 0.38);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 7px 10px;
    font-size: 0.73rem;
    font-weight: 800;
  }

  .view-project:hover {
    border-color: var(--gold);
    color: #7c2d12;
    text-decoration: none;
  }

  .home-shell {
    padding-top: 0;
  }

  .current-projects-section {
    background: #fff;
    padding-block: 38px;
  }

  .current-projects-layout {
    display: grid;
    grid-template-columns: minmax(190px, 0.34fr) minmax(0, 1fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
  }

  .current-projects-layout h2 {
    margin-top: 3px;
    font-size: clamp(1.45rem, 2.6vw, 2.2rem);
  }

  .current-project-list {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .current-project-list article {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 10px;
    align-items: start;
    border: 1px solid var(--border);
    border-radius: 15px;
    background: #fffdf8;
    padding: 14px;
  }

  .current-project-list h3 {
    font-size: 0.93rem;
    line-height: 1.3;
  }

  .current-project-list p {
    margin-top: 4px;
    color: #6b7280;
    font-size: 0.72rem;
  }

  .current-status {
    width: 8px;
    height: 8px;
    margin-top: 5px;
    border-radius: 50%;
    background: #7394b8;
    box-shadow: 0 0 0 4px rgba(115, 148, 184, 0.13);
  }

  .current-active {
    background: #2a8260;
    box-shadow: 0 0 0 4px rgba(42, 130, 96, 0.13);
  }

  .current-progress {
    background: var(--gold);
    box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15);
  }

  .featured-research-section {
    background: #fffdf8;
    padding-block: 52px;
  }

  .featured-research-card {
    display: grid;
    grid-template-columns: minmax(220px, 0.5fr) minmax(0, 1.5fr);
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: #fff;
    box-shadow: 0 12px 28px rgba(63, 47, 31, 0.07);
    color: var(--text);
    padding: 0;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .featured-research-card:hover {
    color: var(--text);
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: 0 18px 38px rgba(63, 47, 31, 0.12);
  }

  .featured-research-image {
    min-height: 220px;
  }

  .featured-research-image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-research-copy {
    display: grid;
    align-content: center;
    padding: clamp(24px, 4vw, 38px);
  }

  .featured-research-meta {
    color: var(--gold-dark);
    font-size: 0.78rem;
    font-weight: 780;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .featured-research-copy h3 {
    max-width: 660px;
    margin-top: 14px;
    color: var(--text);
    font-size: clamp(1.4rem, 2.6vw, 2rem);
  }

  .featured-research-copy > p:not(.featured-research-meta) {
    max-width: 620px;
    margin-top: 16px;
    color: var(--muted);
  }

  .featured-research-copy > span {
    margin-top: 20px;
    color: var(--gold-dark);
    font-weight: 750;
  }

  .reading-strip {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 34px;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 24px;
    background:
      linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(255, 255, 255, 0) 32%),
      var(--paper);
    box-shadow: 0 10px 24px rgba(63, 47, 31, 0.05);
    padding: 24px;
  }

  .research-notes-section {
    padding-block: 38px 68px;
  }

  .research-interests-section {
    background: #fff;
    padding-block: 38px;
  }

  .research-interests-card {
    display: grid;
    grid-template-columns: minmax(240px, 0.72fr) minmax(0, 1.28fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: center;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding-block: 26px;
  }

  .research-interests-card h2 {
    max-width: 470px;
    margin-top: 4px;
    font-size: clamp(1.35rem, 2.4vw, 2rem);
  }

  .research-interests-card > div > p:last-child {
    max-width: 410px;
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.88rem;
  }

  .research-interest-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .research-interest-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    color: #475569;
    font-weight: 680;
  }

  .research-interest-list li::before {
    width: 7px;
    height: 7px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: var(--gold);
    box-shadow: 0 0 0 4px var(--gold-soft);
    content: '';
  }

  .reading-strip h2 a {
    color: var(--text);
  }

  .reading-strip h2 a:hover {
    color: var(--gold-dark);
    text-decoration: none;
  }

  .reading-strip p {
    max-width: 700px;
    margin-top: 12px;
    color: var(--muted);
  }

  .reading-meta {
    display: grid;
    justify-items: end;
    gap: 10px;
  }

  .reading-meta span {
    display: inline-flex;
    border: 1px solid rgba(245, 158, 11, 0.34);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 6px 12px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 720;
  }

  @media (max-width: 1020px) {
    .priority-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .hero-copy {
      max-width: 680px;
    }

    .featured-projects {
      border-top: 1px solid rgba(180, 83, 9, 0.18);
      border-left: 0;
      padding-top: 28px;
      padding-left: 0;
    }

    .current-projects-layout {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 700px) {
    .current-project-list {
      grid-template-columns: 1fr;
    }
    .research-interests-card {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .research-interest-list {
      grid-template-columns: 1fr;
    }

    .reading-strip {
      grid-template-columns: 1fr;
      padding: 24px;
    }

    .featured-research-card {
      grid-template-columns: 1fr;
    }

    .featured-research-image {
      min-height: 230px;
      max-height: 300px;
    }

    .reading-meta {
      justify-items: start;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding: 38px 0 42px;
    }

    .featured-projects-heading {
      align-items: start;
    }

    .priority-project-card {
      grid-template-columns: 82px minmax(0, 1fr);
      gap: 12px;
      min-height: 148px;
      padding-right: 12px;
    }

    .priority-project-card img {
      width: 82px;
      height: 112px;
      grid-row: 1 / span 2;
    }

    .priority-research-meta div {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .view-project {
      grid-column: 2;
      width: fit-content;
      min-height: 30px;
      padding: 5px 9px;
    }
  }
</style>
