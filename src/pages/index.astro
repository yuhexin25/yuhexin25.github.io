---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';

const featuredProjects = projects.slice(0, 3);
const readingNotes = (await getCollection('reading-notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const latestReadingNote = readingNotes[0];
const latestReadingHref = latestReadingNote
  ? `${import.meta.env.BASE_URL}reading-notes/${latestReadingNote.slug}`
  : `${import.meta.env.BASE_URL}reading-notes`;
---

<Layout
  title="Aviation Analytics Portfolio"
  description="Hexin Yu is a Virginia Tech Computational Modeling & Data Analytics student interested in aviation analytics, transportation systems, data visualization, and network analysis."
>
  <section class="hero-section">
    <svg class="route-field" viewBox="0 0 1200 520" aria-hidden="true">
      <path d="M-30 400 C 210 260, 370 270, 610 130 S 1000 50, 1240 180" />
      <path d="M80 120 C 300 210, 420 92, 640 220 S 960 390, 1210 300" />
      <path d="M220 510 C 380 380, 520 390, 720 310 S 980 210, 1180 250" />
      <circle cx="180" cy="318" r="5" />
      <circle cx="610" cy="130" r="5" />
      <circle cx="890" cy="92" r="5" />
      <circle cx="1030" cy="342" r="5" />
    </svg>
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="page-kicker">Virginia Tech / CMDA / portfolio</p>
        <h1>Hexin Yu</h1>
        <p class="hero-subtitle">Computational Modeling & Data Analytics Student<br />Virginia Tech</p>
        <p class="lead">
          Interested in aviation analytics, transportation systems, data visualization, and network analysis.
        </p>
        <div class="button-row">
          <a class="button" href={`${import.meta.env.BASE_URL}projects`}>View Projects</a>
          <a class="button secondary" href="/hexinyu/Hexin-Yu-CV.pdf" target="_blank" rel="noopener noreferrer">Download CV</a>
        </div>
      </div>
      <aside class="hero-panel" aria-label="Portfolio focus summary">
        <div class="network-globe" aria-hidden="true">
          <svg viewBox="0 0 260 260">
            <circle class="globe-ring" cx="130" cy="130" r="96" />
            <ellipse class="globe-line" cx="130" cy="130" rx="44" ry="96" />
            <ellipse class="globe-line" cx="130" cy="130" rx="96" ry="34" />
            <path class="route" d="M58 152 C 92 82, 168 74, 205 118" />
            <path class="route route-alt" d="M76 190 C 126 134, 164 150, 214 72" />
            <circle class="node" cx="58" cy="152" r="6" />
            <circle class="node" cx="205" cy="118" r="6" />
            <circle class="node" cx="76" cy="190" r="5" />
            <circle class="node" cx="214" cy="72" r="5" />
            <path class="plane" d="M139 107 L171 96 L151 124 L148 151 L135 130 L110 127 Z" />
          </svg>
        </div>
        <p class="panel-label">Current focus</p>
        <ul>
          <li>
            <span>01</span>
            Aviation analytics
          </li>
          <li>
            <span>02</span>
            Transportation systems
          </li>
          <li>
            <span>03</span>
            Data visualization and network analysis
          </li>
        </ul>
      </aside>
    </div>
  </section>

  <div class="page-shell home-shell">
    <section class="section first-section">
      <div class="container section-heading">
        <div>
          <p class="page-kicker">Selected work</p>
          <h2>Featured Projects</h2>
        </div>
        <a href={`${import.meta.env.BASE_URL}projects`}>All projects -></a>
      </div>
      <div class="container project-list featured-grid">
        {featuredProjects.map((project) => <ProjectCard {...project} variant="card" />)}
      </div>
    </section>

    <section class="section tint">
      <div class="container two-column">
        <div>
          <p class="page-kicker">Research frame</p>
          <h2>Research Questions</h2>
          <p class="section-note">
            My work starts from questions about where disruptions begin, how they move through route networks,
            and what maps can reveal about airport access and resilience.
          </p>
          <a class="text-link" href={`${import.meta.env.BASE_URL}research`}>Research questions -></a>
        </div>
        <ul class="quiet-list">
          <li>How do hub airports absorb or amplify delay?</li>
          <li>When do regional routes become vulnerable?</li>
          <li>How does delay propagate across airline networks?</li>
          <li>What can data visualization reveal about transportation resilience?</li>
        </ul>
      </div>
    </section>

    {latestReadingNote && (
      <section class="section">
        <div class="container reading-strip">
          <div>
            <p class="page-kicker">Currently Reading</p>
            <h2>
              <a href={latestReadingHref}>{latestReadingNote.data.title}</a>
            </h2>
            <p>{latestReadingNote.data.description}</p>
          </div>
          <div class="reading-meta">
            <span>{latestReadingNote.data.dateRange}</span>
            <a class="text-link" href={latestReadingHref}>Open note -></a>
          </div>
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .hero-section {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(circle at 78% 18%, rgba(245, 158, 11, 0.2), transparent 30%),
      radial-gradient(circle at 16% 78%, rgba(37, 99, 235, 0.13), transparent 34%),
      linear-gradient(135deg, #fffdf8 0%, #fff7ed 48%, #eff6ff 100%);
    background-size: auto, 46px 46px, auto;
    padding: 106px 0 96px;
  }

  .route-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    opacity: 0.5;
    pointer-events: none;
  }

  .route-field path {
    fill: none;
    stroke: rgba(180, 83, 9, 0.18);
    stroke-width: 1.4;
  }

  .route-field circle {
    fill: var(--gold);
    filter: drop-shadow(0 0 10px rgba(245, 158, 11, 0.38));
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(310px, 0.65fr);
    gap: 52px;
    align-items: center;
  }

  .hero-copy {
    max-width: 780px;
  }

  .hero-copy .page-kicker {
    color: var(--gold-dark);
  }

  .hero-copy h1 {
    color: var(--text);
    text-shadow: 0 18px 54px rgba(245, 158, 11, 0.12);
  }

  .hero-copy .lead {
    color: #475569;
  }

  .hero-subtitle {
    margin-top: 12px;
    color: var(--accent-dark);
    font-size: clamp(1rem, 2vw, 1.28rem);
    font-weight: 760;
  }

  .hero-panel {
    border: 1px solid rgba(231, 229, 228, 0.95);
    border-radius: 28px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 248, 235, 0.92)),
      #fff;
    box-shadow: 0 28px 80px rgba(63, 47, 31, 0.12);
    backdrop-filter: blur(12px);
    padding: 24px;
  }

  .network-globe {
    display: grid;
    place-items: center;
    min-height: 238px;
    border: 1px solid rgba(245, 158, 11, 0.18);
    border-radius: 22px;
    background:
      radial-gradient(circle, rgba(245, 158, 11, 0.18), transparent 58%),
      linear-gradient(135deg, #fffdf8, #eff6ff);
    margin-bottom: 20px;
  }

  .network-globe svg {
    width: min(100%, 260px);
  }

  .globe-ring,
  .globe-line {
    fill: none;
    stroke: rgba(37, 99, 235, 0.28);
    stroke-width: 1.5;
  }

  .route {
    fill: none;
    stroke: var(--gold);
    stroke-width: 3;
    stroke-linecap: round;
  }

  .route-alt {
    stroke: var(--accent);
    stroke-width: 2;
    opacity: 0.78;
  }

  .node {
    fill: #fff;
    stroke: var(--gold);
    stroke-width: 2;
    filter: drop-shadow(0 0 8px rgba(245, 158, 11, 0.36));
  }

  .plane {
    fill: var(--text);
    opacity: 0.94;
    filter: drop-shadow(0 8px 14px rgba(63, 47, 31, 0.16));
  }

  .panel-label {
    color: var(--gold-dark);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .hero-panel ul {
    display: grid;
    gap: 0;
    margin: 14px 0 0;
    padding: 0;
    list-style: none;
  }

  .hero-panel li {
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 12px;
    border-top: 1px solid var(--border);
    padding: 15px 0;
    color: var(--text);
    font-weight: 650;
  }

  .hero-panel li:first-child {
    border-top: 0;
  }

  .hero-panel span {
    color: var(--gold-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.84rem;
  }

  .home-shell {
    padding-top: 0;
  }

  .first-section {
    border-top: 0;
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 2rem;
    margin-top: 8px;
  }

  .section-note {
    margin-top: 14px;
    color: var(--muted);
  }

  .reading-strip {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 34px;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: 24px;
    background:
      linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(255, 255, 255, 0) 32%),
      var(--paper);
    box-shadow: 0 16px 38px rgba(63, 47, 31, 0.06);
    padding: 30px;
  }

  .reading-strip h2 a {
    color: var(--text);
  }

  .reading-strip h2 a:hover {
    color: var(--gold-dark);
    text-decoration: none;
  }

  .reading-strip p {
    max-width: 700px;
    margin-top: 12px;
    color: var(--muted);
  }

  .reading-meta {
    display: grid;
    justify-items: end;
    gap: 10px;
  }

  .reading-meta span {
    display: inline-flex;
    border: 1px solid rgba(245, 158, 11, 0.34);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 6px 12px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 720;
  }

  @media (max-width: 1020px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .featured-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero-panel {
      max-width: 620px;
    }
  }

  @media (max-width: 700px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .reading-strip {
      grid-template-columns: 1fr;
      padding: 24px;
    }

    .reading-meta {
      justify-items: start;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding: 74px 0 68px;
    }
  }
</style>
