---
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="article">
    <div class="container article-inner">
      <a class="back-link" href={`${import.meta.env.BASE_URL}blog`}>Back to observations</a>
      <p class="eyebrow">Observation</p>
      <h1>{post.data.title}</h1>
      <p class="meta">
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </p>
      <div class="tag-list">
        {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
      </div>
      <div class="content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .article {
    padding: 52px 0 70px;
  }

  .article-inner {
    max-width: 820px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 24px;
    font-weight: 650;
  }

  .article h1 {
    margin-bottom: 12px;
    font-size: clamp(2rem, 4vw, 3.2rem);
  }

  .content {
    margin-top: 32px;
    border-top: 1px solid var(--border);
    padding-top: 28px;
  }

  .content :global(p) {
    margin: 0 0 18px;
    color: #2c3845;
  }

  .content :global(h2) {
    margin: 32px 0 12px;
    font-size: 1.35rem;
  }
</style>
