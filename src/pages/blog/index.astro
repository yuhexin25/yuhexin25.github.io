---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Blog"
  description="Short observations from Hexin Yu on aviation analytics, hub airports, delay prediction, geographic systems, and dashboard design."
>
  <header class="page-header">
    <div class="container">
      <p class="eyebrow">Blog / Observations</p>
      <h1>Notes on Aviation Data and Networks</h1>
      <p>
        Short reflections on aviation datasets, airport networks, route risk, geospatial visualization,
        and lessons from building analytical dashboards.
      </p>
    </div>
  </header>

  <section class="section">
    <div class="container blog-list">
      {posts.map((post) => (
        <article class="blog-row">
          <div>
            <p class="meta">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
            </p>
            <h2><a href={`${import.meta.env.BASE_URL}blog/${post.id}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
            <div class="tag-list">
              {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>

<style>
  .blog-list {
    display: grid;
    gap: 0;
  }

  .blog-row {
    border-bottom: 1px solid var(--border);
    padding: 24px 0;
  }

  .blog-row:first-child {
    padding-top: 0;
  }

  .blog-row h2 {
    margin: 4px 0 8px;
    font-size: 1.35rem;
  }

  .blog-row p:not(.meta) {
    max-width: 780px;
    color: var(--muted);
  }
</style>
