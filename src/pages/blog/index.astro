---
import Layout from '../../components/Layout.astro';

const base = import.meta.env.BASE_URL;
const posts = [
  { title:"When Celebration Stops an Airport: DCA's July 4 Ground Stop and the Network Impact of Planned Airspace Closures", category:'Airport Operations', description:'How a planned America 250 airspace closure at Reagan National becomes a case study in FAA flow control, passenger spillover, and network resilience.', href:`${base}blog/dca-july-4-ground-stop-network-impact/`, image:`${base}images/blog/dca-7-4-groundstop/dca-control-tower-context.jpg`, imageAlt:'DCA control tower and terminal area with an aircraft flying above Reagan National Airport.', time:'9 min read' },
  { title:'Why World Cup 2026 Is Different from Qatar 2022', category:'Transportation Geography', description:'How a compact tournament became a continental transportation problem - and why aviation now matters between matches.', href:`${base}blog/world-cup-2026-vs-qatar-2022/`, image:`${base}research/world-cup-network-hero.png`, imageAlt:'Flight paths connecting World Cup host cities across North America.', time:'6 min read' },
  { title:'World Cup 2026 and the U.S. Aviation System', category:'Airline Operations', description:'Demand waves, summer thunderstorms, and what I observed while traveling through Houston during consecutive matchdays.', href:`${base}blog/world-cup-us-aviation-system/`, image:`${base}research/houston-match-attendance.jpg`, imageAlt:'Germany versus Curacao scoreboard and attendance display in Houston.', time:'7 min read' },
  { title:'Hubs, Alliances, and World Cup Mobility', category:'Aviation Networks', description:'How the tournament temporarily reweights passenger flows across a network shaped by alliances, central hubs, and connectivity.', href:`${base}blog/hubs-alliances-world-cup-mobility/`, image:`${base}blog/hubs-alliances-world-cup-mobility-hero.png`, imageAlt:'North American airline hubs connected by alliance network flows.', time:'8 min read' },
];
---
<Layout title="Blog" description="Research-driven writing by Hexin Yu on aviation networks, transportation geography, airline operations, and resilience.">
  <section class="blog-index-hero"><div class="container"><p class="page-kicker">Blog</p><h1>Aviation systems in context</h1><p>Aviation observations, transportation analysis, and research-oriented commentary.</p></div></section>
  <section class="container blog-index"><div class="post-grid">{posts.map((post) => <a class="post-card" href={post.href}><img src={post.image} alt={post.imageAlt} /><div><p>{post.category}</p><h2>{post.title}</h2><span>{post.description}</span><small>June 2026 · {post.time}</small></div></a>)}</div></section>
</Layout>
<style>
  .blog-index-hero{border-bottom:1px solid var(--border);background:#fffdf8;padding:clamp(54px,8vw,86px) 0 clamp(46px,7vw,72px)}.blog-index-hero h1{font-size:clamp(2.55rem,7vw,6rem)}.blog-index-hero>div>p:last-child{max-width:700px;margin-top:20px;color:#526071;font-size:clamp(1rem,2vw,1.2rem)}.blog-index{padding-block:clamp(44px,7vw,68px) clamp(72px,9vw,100px)}.post-grid{display:grid;gap:clamp(18px,3vw,26px)}.post-card{display:grid;grid-template-columns:minmax(220px,.72fr) minmax(0,1.28fr);overflow:hidden;border:1px solid var(--border);border-radius:20px;background:#fff;color:var(--text);transition:border-color 180ms ease}.post-card:hover{border-color:var(--border-strong);color:var(--text);text-decoration:none}.post-card img{width:100%;height:100%;min-height:260px;object-fit:cover}.post-card>div{display:grid;align-content:center;min-width:0;padding:clamp(24px,4vw,34px)}.post-card p{color:var(--gold-dark);font-size:.74rem;font-weight:800;letter-spacing:.09em;text-transform:uppercase}.post-card h2{margin-top:10px;font-size:clamp(1.35rem,3vw,2.35rem);overflow-wrap:anywhere}.post-card span{margin-top:14px;color:#64748b}.post-card small{margin-top:22px;color:#8a7c6b}.post-card:nth-child(3) img{background:#fff7ed}@media(max-width:760px){.post-card{grid-template-columns:1fr}.post-card img{height:auto;min-height:0;max-height:none;aspect-ratio:16/9}.post-card>div{padding:24px}}@media(max-width:430px){.post-card{border-radius:16px}.post-card>div{padding:20px}}
</style>
