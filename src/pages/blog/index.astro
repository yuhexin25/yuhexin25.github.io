---
import Layout from '../../components/Layout.astro';

const base = import.meta.env.BASE_URL;
const posts = [
  { title:'Why World Cup 2026 Is Different from Qatar 2022', category:'Transportation Geography', description:'How a compact tournament became a continental transportation problem - and why aviation now matters between matches.', href:`${base}blog/world-cup-2026-vs-qatar-2022/`, image:`${base}research/world-cup-network-hero.png`, time:'6 min read' },
  { title:'World Cup 2026 and the U.S. Aviation System', category:'Airline Operations', description:'Demand waves, summer thunderstorms, and what I observed while traveling through Houston during consecutive matchdays.', href:`${base}blog/world-cup-us-aviation-system/`, image:`${base}research/houston-match-attendance.jpg`, time:'7 min read' },
  { title:'Hubs, Alliances, and World Cup Mobility', category:'Aviation Networks', description:'How the tournament temporarily reweights passenger flows across a network shaped by alliances, central hubs, and connectivity.', href:`${base}blog/hubs-alliances-world-cup-mobility/`, image:`${base}blog/hubs-alliances-world-cup-mobility-hero.png`, time:'8 min read' },
];
---
<Layout title="Blog" description="Research-driven writing by Hexin Yu on aviation networks, transportation geography, airline operations, and resilience.">
  <section class="blog-index-hero"><div class="container"><p class="page-kicker">Blog</p><h1>Aviation systems in context</h1><p>Focused commentary connecting data, transportation geography, and real operating problems.</p></div></section>
  <section class="container blog-index"><div class="post-grid">{posts.map((post) => <a class="post-card" href={post.href}><img src={post.image} alt="" /><div><p>{post.category}</p><h2>{post.title}</h2><span>{post.description}</span><small>June 2026 · {post.time}</small></div></a>)}</div></section>
</Layout>
<style>
  .blog-index-hero{border-bottom:1px solid var(--border);background:linear-gradient(135deg,#fffdf8,#fff4df 55%,#e9f2ff);padding:86px 0 72px}.blog-index-hero h1{font-size:clamp(3rem,7vw,6rem)}.blog-index-hero>div>p:last-child{max-width:700px;margin-top:20px;color:#526071;font-size:1.2rem}.blog-index{padding-block:68px 100px}.post-grid{display:grid;gap:26px}.post-card{display:grid;grid-template-columns:minmax(260px,.8fr) minmax(0,1.2fr);overflow:hidden;border:1px solid var(--border);border-radius:24px;background:#fff;box-shadow:0 16px 38px rgba(63,47,31,.07);color:var(--text);transition:transform 180ms ease,box-shadow 180ms ease}.post-card:hover{color:var(--text);text-decoration:none;transform:translateY(-3px);box-shadow:0 22px 48px rgba(63,47,31,.12)}.post-card img{width:100%;height:100%;min-height:300px;object-fit:cover}.post-card>div{display:grid;align-content:center;padding:34px}.post-card p{color:var(--gold-dark);font-size:.74rem;font-weight:800;letter-spacing:.09em;text-transform:uppercase}.post-card h2{margin-top:10px;font-size:clamp(1.55rem,3vw,2.35rem)}.post-card span{margin-top:14px;color:#64748b}.post-card small{margin-top:22px;color:#8a7c6b}.post-card:nth-child(3) img{background:#fff7ed}@media(max-width:720px){.post-card{grid-template-columns:1fr}.post-card img{min-height:220px;max-height:280px}.post-card>div{padding:25px}}
</style>
