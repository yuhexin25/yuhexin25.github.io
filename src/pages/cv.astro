---
import Layout from '../components/Layout.astro';
import { projects } from '../data/projects';

const skills = [
  'Python',
  'Pandas',
  'SQL',
  'JavaScript',
  'Astro',
  'GIS',
  'GeoJSON',
  'QGIS',
  'data visualization',
  'transportation analytics',
];
---

<Layout
  title="CV"
  description="Hexin Yu's CV with education, technical skills, selected aviation analytics projects, and a downloadable resume PDF."
>
  <div class="page-shell">
    <header class="container page-intro">
      <p class="page-kicker">CV</p>
      <h1>Hexin Yu</h1>
      <p class="lead">
        Computational Modeling & Data Analytics student at Virginia Tech with interests in aviation analytics,
        GIS, transportation networks, and data visualization.
      </p>
      <a class="button" href="/hexinyu/Hexin-Yu-CV.pdf" target="_blank" rel="noopener noreferrer">Download CV</a>
    </header>

    <section class="container cv-list">
      <article>
        <h2>Education</h2>
        <div>
          <h3>Virginia Tech</h3>
          <p>Computational Modeling & Data Analytics student</p>
          <p>Focus: aviation analytics, transportation systems, GIS, and data visualization.</p>
        </div>
      </article>

      <article>
        <h2>Technical Skills</h2>
        <div class="tag-row">
          {skills.map((skill) => <span>{skill}</span>)}
        </div>
      </article>

      <article>
        <h2>Selected Projects</h2>
        <ul class="quiet-list">
          {projects.map((project) => (
            <li>
              <a href={project.href} target="_blank" rel="noopener noreferrer">{project.title}</a>
              <span>{project.year}</span>
            </li>
          ))}
        </ul>
      </article>

      <article>
        <h2>Contact</h2>
        <ul class="quiet-list">
          <li><a href="mailto:hexinyu@example.com">hexinyu@example.com</a></li>
          <li><a href="https://github.com/" target="_blank" rel="noopener noreferrer">GitHub</a></li>
          <li><a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer">LinkedIn</a></li>
        </ul>
      </article>
    </section>
  </div>
</Layout>

<style>
  .cv-list {
    display: grid;
    gap: 0;
  }

  .cv-list article {
    display: grid;
    grid-template-columns: minmax(220px, 0.36fr) minmax(0, 0.64fr);
    gap: 36px;
    border-top: 1px solid var(--border);
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.82), transparent);
    padding: 28px 0;
  }

  .cv-list p {
    color: var(--muted);
  }

  .page-intro .button {
    margin-top: 28px;
  }

  .cv-list .quiet-list li {
    display: grid;
    min-height: 96px;
    gap: 8px;
  }

  .cv-list .quiet-list a {
    color: var(--text);
    font-weight: 720;
  }

  .cv-list .quiet-list a:hover {
    color: var(--accent);
  }

  .cv-list .quiet-list span {
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.88rem;
  }

  @media (max-width: 760px) {
    .cv-list article {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
