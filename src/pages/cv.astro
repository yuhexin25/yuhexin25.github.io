---
import Layout from '../components/Layout.astro';

const base = import.meta.env.BASE_URL;

const coursework = [
  'Calculus I (A)',
  'Calculus II (A)',
  'General Physics (A)',
  'Statistical Methods (A)',
  'Intro to Python (A)',
  'First-Year Writing (A)',
  'Data in Social Context (A)',
];

const skills = [
  'Python',
  'Data Analysis',
  'Statistics',
  'Scientific Computing',
  'Team Leadership',
  'Public Speaking',
];

const experiences = [
  {
    title: 'IBM Skills Build AI Experiential Learning Lab',
    role: 'Team Leader',
    detail: 'Led a 4-member team developing a healthcare chatbot.',
  },
  {
    title: 'BITS (Building Impactful Tech with Students)',
    role: 'Developer - Turing Note Project',
    detail: 'Selected through a competitive interview process.',
  },
  {
    title: 'Beijing No. 4 High School Student Union',
    role: 'Head of Finance',
  },
];

const activities = [
  'Virginia Tech Design Build Fly Club',
  'CMDA Club',
  'Virginia Tech Chinese Soccer Club',
  'Beijing No.4 High School Soccer Team Captain',
];

const volunteerWork = [
  'Yulan Primary School Volunteer Head Teacher',
  'Beijing Planetarium Volunteer Docent',
];

const awards = [
  'Best Speaker Award',
  'Best All-Around Student Award',
  'High School Soccer League Champion',
];
---

<Layout
  title="CV"
  description="Hexin Yu's CV with education, experience, coursework, skills, activities, volunteer work, awards, and contact information."
>
  <div class="page-shell">
    <header class="container page-intro cv-intro">
      <p class="page-kicker">CV</p>
      <h1>Hexin Yu</h1>
      <p class="lead">
        Computational Modeling & Data Analytics student at Virginia Tech interested in aviation analytics,
        transportation systems, data visualization, and network analysis.
      </p>
      <a class="button" href={`${base}Hexin-Yu-CV.pdf`} target="_blank" rel="noopener noreferrer">Download CV</a>
    </header>

    <section class="container cv-list" aria-label="CV details">
      <article>
        <h2>Education</h2>
        <div class="entry-stack">
          <div>
            <h3>Virginia Tech</h3>
            <p>B.S. Computational Modeling & Data Analytics</p>
            <p>College of Science</p>
            <p>Expected Graduation: 2029</p>
            <dl class="academic-metrics" aria-label="Academic highlights">
              <div>
                <dt>GPA</dt>
                <dd>4.0 / 4.0</dd>
              </div>
              <div>
                <dt>Academic Achievement</dt>
                <dd>All completed university coursework has been completed with grades of A.</dd>
              </div>
            </dl>
            <div class="coursework-block">
              <h4>Selected Coursework</h4>
              <div class="tag-row">
                {coursework.map((item) => <span>{item}</span>)}
              </div>
            </div>
          </div>
          <div>
            <h3>Beijing No. 4 High School</h3>
          </div>
        </div>
      </article>

      <article>
        <h2>Experience</h2>
        <div class="entry-stack">
          {experiences.map((experience) => (
            <div>
              <h3>{experience.title}</h3>
              <p class="role">{experience.role}</p>
              {experience.detail && <p>{experience.detail}</p>}
            </div>
          ))}
        </div>
      </article>

      <article>
        <h2>Coursework & Skills</h2>
        <div class="skills-layout">
          <div>
            <h3>Skills</h3>
            <div class="tag-row">
              {skills.map((skill) => <span>{skill}</span>)}
            </div>
          </div>
        </div>
      </article>

      <article>
        <h2>Activities</h2>
        <ul class="quiet-list compact-list">
          {activities.map((activity) => <li>{activity}</li>)}
        </ul>
      </article>

      <article>
        <h2>Volunteer Work</h2>
        <ul class="quiet-list compact-list">
          {volunteerWork.map((work) => <li>{work}</li>)}
        </ul>
      </article>

      <article>
        <h2>Awards</h2>
        <ul class="quiet-list compact-list">
          {awards.map((award) => <li>{award}</li>)}
        </ul>
      </article>

      <article>
        <h2>Contact</h2>
        <ul class="quiet-list contact-list">
          <li><a href="mailto:yuhexin25@vt.edu">yuhexin25@vt.edu</a></li>
          <li><a href="https://github.com/yuhexin25" target="_blank" rel="noopener noreferrer">GitHub</a></li>
        </ul>
      </article>
    </section>
  </div>
</Layout>

<style>
  .cv-intro .button {
    margin-top: 28px;
  }

  .cv-list {
    display: grid;
    gap: 0;
  }

  .cv-list article {
    display: grid;
    grid-template-columns: minmax(180px, 0.34fr) minmax(0, 0.66fr);
    gap: clamp(20px, 4vw, 36px);
    border-top: 1px solid var(--border);
    background: linear-gradient(90deg, rgba(255, 248, 235, 0.82), transparent);
    padding: clamp(24px, 4vw, 30px) 0;
  }

  .cv-list p {
    color: var(--muted);
  }

  .entry-stack {
    display: grid;
    gap: 22px;
  }

  .role {
    color: var(--gold-dark);
    font-weight: 720;
  }

  .academic-metrics {
    display: grid;
    grid-template-columns: minmax(min(100%, 120px), 0.34fr) minmax(0, 0.66fr);
    gap: 12px;
    max-width: 640px;
    margin: 18px 0 0;
  }

  .academic-metrics div {
    display: contents;
  }

  .academic-metrics dt,
  .coursework-block h4 {
    color: var(--gold-dark);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .academic-metrics dd {
    margin: 0;
    color: var(--text);
    font-weight: 680;
  }

  .coursework-block {
    margin-top: 22px;
  }

  .coursework-block .tag-row {
    margin-top: 12px;
  }

  .skills-layout {
    display: grid;
    gap: 28px;
  }

  .skills-layout h3 {
    margin-bottom: 4px;
  }

  .compact-list li,
  .contact-list li {
    min-height: auto;
  }

  .contact-list a {
    color: var(--text);
    font-weight: 720;
  }

  .contact-list a:hover {
    color: var(--gold-dark);
  }

  @media (max-width: 760px) {
    .cv-list article {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .academic-metrics {
      grid-template-columns: 1fr;
      gap: 6px;
    }
  }

  @media (max-width: 430px) {
    .cv-intro .button {
      width: 100%;
    }

    .tag-row {
      gap: 8px;
    }
  }
</style>
