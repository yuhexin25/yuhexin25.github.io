---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Layout from '../../../components/Layout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('reading-notes');

  return notes.map((note) => ({
    params: { source: note.data.source.slug, note: note.data.noteSlug },
    props: { note },
  }));
}

interface Props {
  note: CollectionEntry<'reading-notes'>;
}

const { note } = Astro.props;
const { Content } = await render(note);
const sourceHref = `${import.meta.env.BASE_URL}reading-notes/${note.data.source.slug}`;
---

<Layout title={`${note.data.title} | ${note.data.source.name}`} description={note.data.description}>
  <article class="note-page">
    <header class="note-hero">
      <div class="container note-header">
        <p class="page-kicker">{note.data.source.category} / {note.data.source.name}</p>
        <h1>{note.data.title}</h1>
        <p class="lead">{note.data.description}</p>
        <div class="note-topic">{note.data.topic}</div>
      </div>
    </header>

    <div class="container note-layout">
      <aside class="source-panel" aria-label="Source details">
        <h2>Source</h2>
        <a href={note.data.source.url} target="_blank" rel="noopener noreferrer">{note.data.sourceTitle}</a>
        {note.data.authors && <span>{note.data.authors}</span>}
        <span>{note.data.source.name}</span>
        <a class="source-link" href={sourceHref}>All {note.data.source.name} notes -></a>
      </aside>

      <div class="reading-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .note-page {
    padding-bottom: 92px;
  }

  .note-hero {
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(circle at 82% 16%, rgba(245, 158, 11, 0.18), transparent 28rem),
      linear-gradient(135deg, #fffdf8 0%, #fff7ed 50%, #eff6ff 100%);
    padding: 72px 0 64px;
  }

  .note-header {
    max-width: 900px;
  }

  .note-header h1 {
    font-size: clamp(2.6rem, 6vw, 5.2rem);
  }

  .note-topic {
    display: inline-flex;
    margin-top: 24px;
    border: 1px solid rgba(245, 158, 11, 0.34);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 6px 12px;
    font-size: 0.86rem;
    font-weight: 720;
  }

  .note-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 720px);
    gap: 54px;
    align-items: start;
    padding-top: 58px;
  }

  .source-panel {
    position: sticky;
    top: 104px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--paper);
    box-shadow: 0 14px 34px rgba(63, 47, 31, 0.055);
    padding: 22px;
  }

  .source-panel h2 {
    font-size: 1rem;
    color: var(--gold-dark);
  }

  .source-panel a:first-of-type {
    display: block;
    margin-top: 14px;
    color: var(--text);
    font-weight: 760;
  }

  .source-panel span {
    display: block;
    margin-top: 8px;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .source-link {
    display: inline-flex;
    margin-top: 18px;
    font-size: 0.94rem;
    font-weight: 720;
  }

  .reading-content {
    max-width: 720px;
    color: #334155;
    font-size: 1.04rem;
    line-height: 1.82;
  }

  .reading-content :global(h2) {
    margin-top: 46px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    color: var(--text);
    font-size: 1.55rem;
  }

  .reading-content :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  .reading-content :global(p) {
    margin-top: 16px;
  }

  .reading-content :global(ul) {
    display: grid;
    gap: 12px;
    margin: 18px 0 0;
    padding-left: 22px;
  }

  @media (max-width: 900px) {
    .note-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .source-panel {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .note-hero {
      padding: 54px 0 48px;
    }

    .note-layout {
      padding-top: 36px;
    }
  }
</style>
