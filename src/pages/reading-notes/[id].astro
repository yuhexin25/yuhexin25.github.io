---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Layout from '../../components/Layout.astro';

export async function getStaticPaths() {
  const notes = await getCollection('readingNotes');

  return notes.map((note) => ({
    params: { id: note.id },
    props: { note },
  }));
}

interface Props {
  note: CollectionEntry<'readingNotes'>;
}

const { note } = Astro.props;
const { Content } = await render(note);
---

<Layout title={note.data.title} description={note.data.description}>
  <article class="note-page">
    <header class="note-hero">
      <div class="container note-header">
        <p class="page-kicker">Reading Notes</p>
        <h1>{note.data.title}</h1>
        <p class="lead">{note.data.description}</p>
        <div class="note-date">{note.data.dateRange}</div>
      </div>
    </header>

    <div class="container note-layout">
      <aside class="source-panel" aria-label="Sources">
        <h2>Sources</h2>
        <ol>
          {note.data.sources.map((source) => (
            <li>
              <a href={source.url} target="_blank" rel="noopener noreferrer">{source.title}</a>
              {source.authors && <span>{source.authors}</span>}
              {source.publisher && <span>{source.publisher}</span>}
              {source.note && <em>{source.note}</em>}
            </li>
          ))}
        </ol>
      </aside>

      <div class="reading-content">
        <Content />
      </div>
    </div>
  </article>
</Layout>

<style>
  .note-page {
    padding-bottom: 92px;
  }

  .note-hero {
    border-bottom: 1px solid var(--border);
    background:
      radial-gradient(circle at 82% 16%, rgba(245, 158, 11, 0.18), transparent 28rem),
      linear-gradient(135deg, #fffdf8 0%, #fff7ed 50%, #eff6ff 100%);
    padding: 72px 0 64px;
  }

  .note-header {
    max-width: 900px;
  }

  .note-header h1 {
    font-size: clamp(2.6rem, 6vw, 5.2rem);
  }

  .note-date {
    display: inline-flex;
    margin-top: 24px;
    border: 1px solid rgba(245, 158, 11, 0.34);
    border-radius: 999px;
    background: var(--gold-soft);
    color: var(--gold-dark);
    padding: 6px 12px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 720;
  }

  .note-layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 720px);
    gap: 54px;
    align-items: start;
    padding-top: 58px;
  }

  .source-panel {
    position: sticky;
    top: 104px;
    border: 1px solid var(--border);
    border-radius: 20px;
    background: var(--paper);
    box-shadow: 0 14px 34px rgba(63, 47, 31, 0.055);
    padding: 22px;
  }

  .source-panel h2 {
    font-size: 1rem;
    color: var(--gold-dark);
  }

  .source-panel ol {
    display: grid;
    gap: 16px;
    margin: 18px 0 0;
    padding-left: 20px;
  }

  .source-panel li {
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .source-panel a {
    display: block;
    color: var(--text);
    font-weight: 700;
  }

  .source-panel span,
  .source-panel em {
    display: block;
    margin-top: 4px;
  }

  .reading-content {
    max-width: 720px;
    color: #334155;
    font-size: 1.04rem;
    line-height: 1.82;
  }

  .reading-content :global(h2) {
    margin-top: 46px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
    color: var(--text);
    font-size: 1.55rem;
  }

  .reading-content :global(h2:first-child) {
    margin-top: 0;
    padding-top: 0;
    border-top: 0;
  }

  .reading-content :global(p) {
    margin-top: 16px;
  }

  .reading-content :global(ul) {
    display: grid;
    gap: 12px;
    margin: 18px 0 0;
    padding-left: 22px;
  }

  .reading-content :global(blockquote) {
    margin: 18px 0;
    border-left: 4px solid var(--gold);
    background: #fff8eb;
    border-radius: 0 14px 14px 0;
    padding: 16px 18px;
    color: var(--warm-ink);
    font-size: 1rem;
  }

  .reading-content :global(blockquote p) {
    margin: 0;
  }

  @media (max-width: 900px) {
    .note-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .source-panel {
      position: static;
    }
  }

  @media (max-width: 640px) {
    .note-hero {
      padding: 54px 0 48px;
    }

    .note-layout {
      padding-top: 36px;
    }
  }
</style>
