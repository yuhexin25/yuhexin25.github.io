---
import { getCollection } from 'astro:content';
import Layout from '../../components/Layout.astro';

const notes = (await getCollection('reading-notes')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const noteHref = (slug: string) => `${import.meta.env.BASE_URL}reading-notes/${slug}`;
---

<Layout
  title="Reading Notes"
  description="Structured reading notes by Hexin Yu on aviation analytics, transportation systems, airline networks, and flight operations."
>
  <div class="reading-page">
    <header class="container reading-intro">
      <p class="page-kicker">Reading Notes</p>
      <h1>Structured aviation reading log</h1>
      <p class="lead">
        Articles, industry reports, and research papers that shape my interests in aviation analytics,
        transportation systems, airline networks, and flight operations.
      </p>
    </header>

    <section class="container notes-list" aria-label="Reading notes">
      {notes.map((note) => (
        <article class="note-card">
          <div class="note-meta">
            <span>{note.data.dateRange}</span>
            <span>{note.data.sources.length} sources</span>
          </div>
          <div class="note-body">
            <h2>
              <a href={noteHref(note.slug)}>{note.data.title}</a>
            </h2>
            <p>{note.data.description}</p>
            <a class="text-link" href={noteHref(note.slug)}>Read note -></a>
          </div>
        </article>
      ))}
    </section>
  </div>
</Layout>

<style>
  .reading-page {
    padding: 72px 0 92px;
  }

  .reading-intro {
    max-width: 900px;
    margin-bottom: 42px;
  }

  .notes-list {
    display: grid;
    gap: 18px;
  }

  .note-card {
    display: grid;
    grid-template-columns: 220px minmax(0, 1fr);
    gap: 32px;
    border: 1px solid var(--border);
    border-radius: 22px;
    background:
      linear-gradient(135deg, rgba(245, 158, 11, 0.08), rgba(255, 255, 255, 0) 34%),
      var(--paper);
    box-shadow: 0 14px 32px rgba(63, 47, 31, 0.055);
    padding: 28px;
    transition:
      border-color 160ms ease,
      box-shadow 160ms ease,
      transform 160ms ease;
  }

  .note-card:hover {
    border-color: rgba(245, 158, 11, 0.45);
    box-shadow: 0 20px 46px rgba(63, 47, 31, 0.09);
    transform: translateY(-2px);
  }

  .note-meta {
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: var(--gold-dark);
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.86rem;
    font-weight: 720;
  }

  .note-body h2 {
    font-size: clamp(1.35rem, 2.5vw, 2rem);
  }

  .note-body h2 a {
    color: var(--text);
  }

  .note-body h2 a:hover {
    color: var(--gold-dark);
    text-decoration: none;
  }

  .note-body p {
    max-width: 760px;
    margin-top: 12px;
    color: var(--muted);
  }

  @media (max-width: 760px) {
    .reading-page {
      padding: 48px 0 64px;
    }

    .note-card {
      grid-template-columns: 1fr;
      gap: 18px;
      padding: 22px;
    }
  }
</style>
