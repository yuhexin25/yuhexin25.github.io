---
interface Props { id:string; title:string; points:any[]; flows:any[]; bounds:[[number,number],[number,number]]; caption:string; source:string; fallback:string; legend:{label:string;color:string}[]; height?:string; }
const { id,title,points,flows,bounds,caption,source,fallback,legend,height='480px' }=Astro.props;
const config=encodeURIComponent(JSON.stringify({points,flows,bounds}));
---
<figure class="flow-map-figure">
  <div class="flow-map-title"><strong>{title}</strong><div>{legend.map((item)=><span><i style={`background:${item.color}`}></i>{item.label}</span>)}</div></div>
  <div id={id} class="flow-map" data-flow-map data-config={config} style={`height:${height}`} aria-label={title}></div>
  <details data-map-fallback hidden><summary>Text alternative</summary><p>{fallback}</p></details>
  <figcaption>{caption}<span>Source: {source}</span></figcaption>
</figure>
<script>
  import { initFlowMaps } from '../scripts/mapRuntime';
  const startFlowMaps = () => {
    if (typeof window !== 'undefined') initFlowMaps();
  };
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', startFlowMaps, { once: true });
  else startFlowMaps();
</script>
<style>
  .flow-map-figure{margin:46px 0}.flow-map-title{display:flex;justify-content:space-between;gap:14px;border:1px solid #d9dee7;border-bottom:0;border-radius:18px 18px 0 0;background:#172033;padding:13px 17px;color:#fff}.flow-map-title>div{display:flex;flex-wrap:wrap;gap:10px}.flow-map-title span{display:inline-flex;align-items:center;gap:5px;color:#dbe6f7;font-size:.68rem}.flow-map-title i{width:16px;height:3px;border-radius:3px}.flow-map{position:relative;width:100%;height:55vh;min-height:420px;max-height:640px;border:1px solid #d9dee7;background:#e9eef4}.flow-map.map-unavailable::after{display:grid;height:100%;place-items:center;padding:20px;color:#64748b;content:'Interactive flow map unavailable. Use the text alternative.'}.flow-map-figure details{border:1px solid #d9dee7;border-top:0;padding:9px 14px;color:#64748b;font-size:.78rem}.flow-map-figure details p{margin-top:8px!important;font-family:inherit!important;font-size:.8rem!important}.flow-map-figure figcaption{margin-top:12px;color:#6b7280;font-size:.8rem;line-height:1.55}.flow-map-figure figcaption span{display:block}@media(max-width:640px){.flow-map-title{display:grid}.flow-map{height:55vh!important;min-height:420px}}
</style>
