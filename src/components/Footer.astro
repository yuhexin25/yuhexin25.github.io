---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-main">
      <p class="footer-title">Hexin Yu</p>
      <p>
        Computational Modeling & Data Analytics student at Virginia Tech exploring aviation analytics,
        geospatial visualization, and transportation systems.
      </p>
    </div>
    <div class="footer-meta">
      <div class="footer-links">
        <a href="mailto:hexinyu@example.com">Email</a>
        <a href="https://github.com/" target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href="https://www.linkedin.com/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
      </div>
      <p>&copy; {year} Hexin Yu</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: #0f172a;
    color: var(--muted);
  }

  .footer-inner {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    min-height: 190px;
    padding: 44px 0;
    gap: 48px;
  }

  .footer-main {
    max-width: 560px;
  }

  .footer-main p:last-child,
  .footer-meta p {
    color: #94a3b8;
  }

  .footer-title {
    margin-bottom: 10px;
    color: #f8fafc;
    font-size: 1.18rem;
    font-weight: 780;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
  }

  .footer-links a {
    color: #dbeafe;
  }

  .footer-meta {
    display: grid;
    justify-items: end;
    gap: 18px;
  }

  @media (max-width: 640px) {
    .footer-inner {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding: 34px 0;
      gap: 24px;
    }

    .footer-meta {
      justify-items: start;
    }
  }
</style>
