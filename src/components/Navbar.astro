---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/research', label: 'Research' },
  { href: '/observations', label: 'Observations' },
  { href: '/cv', label: 'CV' },
];

const base = import.meta.env.BASE_URL;
const basePath = base.replace(/\/$/, '');
const rawPath = Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || '/'
  : Astro.url.pathname;
const currentPath = rawPath.replace(/\/$/, '') || '/';
const withBase = (href: string) => `${base}${href.replace(/^\//, '')}`;
---

<header class="site-header">
  <nav class="container nav" aria-label="Primary navigation">
    <a class="brand" href={withBase('/')}>
      <span class="brand-mark">HY</span>
      <span>Hexin Yu</span>
    </a>
    <div class="nav-links">
      {navItems.map((item) => {
        const itemPath = item.href.replace(/\/$/, '') || '/';
        const isActive = currentPath === itemPath || (item.href !== '/' && currentPath.startsWith(itemPath));
        return (
          <a href={withBase(item.href)} aria-current={isActive ? 'page' : undefined}>
            {item.label}
          </a>
        );
      })}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid rgba(216, 224, 234, 0.82);
    background: rgba(248, 250, 252, 0.88);
    backdrop-filter: blur(16px);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 74px;
    gap: 20px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-weight: 760;
    letter-spacing: -0.01em;
  }

  .brand:hover {
    color: var(--text);
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid rgba(40, 84, 197, 0.18);
    border-radius: 10px;
    background: #fff;
    color: var(--accent-dark);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 8px;
    border: 1px solid rgba(216, 224, 234, 0.9);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    padding: 5px;
  }

  .nav-links a {
    color: #3a424a;
    border-radius: 999px;
    padding: 7px 12px;
    font-size: 0.92rem;
    font-weight: 650;
  }

  .nav-links a:hover,
  .nav-links a[aria-current='page'] {
    background: var(--accent-soft);
    color: var(--accent-dark);
    text-decoration: none;
    box-shadow: none;
  }

  @media (max-width: 660px) {
    .nav {
      align-items: flex-start;
      flex-direction: column;
      padding: 12px 0;
      gap: 10px;
    }

    .nav-links {
      width: 100%;
      justify-content: flex-start;
      border-radius: 16px;
    }
  }
</style>
