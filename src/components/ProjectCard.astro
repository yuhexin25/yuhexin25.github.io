---
interface Props {
  title: string;
  year: string;
  description: string;
  tags: string[];
  href?: string;
  variant?: 'row' | 'card';
}

const { title, year, description, tags, href = '#', variant = 'row' } = Astro.props;
---

<article class:list={['project-card', variant === 'card' && 'project-card--card']}>
  <div class="project-year">{year}</div>
  <div class="project-body">
    <div class="project-title-row">
      <span class="project-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M3 12.2 21 4l-5.8 16-3.6-6.6L3 12.2Z" />
          <path d="m11.6 13.4 4.8-5.1" />
        </svg>
      </span>
      <h3>{title}</h3>
    </div>
    <p>{description}</p>
    <ul class="tag-list" aria-label={`${title} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <a class="visit-link" href={href} target="_blank" rel="noopener noreferrer">Visit site -></a>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    grid-template-columns: 92px minmax(0, 1fr);
    gap: 28px;
    border-top: 1px solid var(--border);
    padding: 28px 0;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .project-card:hover {
    border-color: var(--border-strong);
  }

  .project-year {
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.35;
  }

  .project-body {
    max-width: 760px;
  }

  .project-title-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
  }

  .project-icon {
    display: inline-grid;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid rgba(37, 99, 235, 0.18);
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--accent);
  }

  .project-icon svg {
    width: 18px;
    height: 18px;
  }

  .project-icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  h3 {
    margin-bottom: 0;
    font-size: clamp(1.2rem, 2vw, 1.55rem);
    font-weight: 520;
  }

  p {
    color: var(--muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 18px 0 12px;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    color: #536170;
    font-size: 0.9rem;
  }

  .tag-list li::before {
    content: '#';
    color: var(--accent);
  }

  .visit-link {
    display: inline-block;
    margin-top: 4px;
    font-size: 0.94rem;
    font-weight: 760;
  }

  .project-card--card {
    min-height: 340px;
    grid-template-columns: 1fr;
    gap: 18px;
    border: 1px solid var(--border);
    border-radius: 18px;
    background:
      linear-gradient(180deg, rgba(37, 99, 235, 0.045), transparent 42%),
      var(--paper);
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.055);
    padding: 24px;
  }

  .project-card--card:hover {
    background:
      linear-gradient(180deg, rgba(37, 99, 235, 0.075), transparent 46%),
      var(--paper);
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .project-card--card .project-year {
    display: inline-flex;
    width: fit-content;
    border: 1px solid rgba(37, 99, 235, 0.16);
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-dark);
    padding: 4px 10px;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .project-card--card .project-body {
    display: grid;
    align-content: start;
    min-height: 250px;
  }

  .project-card--card h3 {
    font-size: clamp(1.35rem, 2.3vw, 1.85rem);
    letter-spacing: -0.02em;
  }

  .project-card--card .visit-link {
    align-self: end;
    margin-top: 18px;
  }

  @media (max-width: 640px) {
    .project-card {
      grid-template-columns: 1fr;
      gap: 8px;
      padding: 24px 0;
    }
  }
</style>
