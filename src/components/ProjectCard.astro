---
interface Props {
  title: string;
  year: string;
  description: string;
  tags: string[];
  href?: string;
  githubHref?: string;
  image?: string;
  imageAlt?: string;
  variant?: 'row' | 'card';
}

const {
  title,
  year,
  description,
  tags,
  href,
  githubHref,
  image,
  imageAlt = `${title} project preview`,
  variant = 'card',
} = Astro.props;

const imageSrc = image ? `${import.meta.env.BASE_URL}${image.replace(/^\//, '')}` : undefined;
---

<article class:list={['project-card', variant === 'card' && 'project-card--card']}>
  {imageSrc && (
    <div class="project-preview">
      <img src={imageSrc} alt={imageAlt} loading="lazy" />
    </div>
  )}
  <div class="project-year">{year}</div>
  <div class="project-body">
    <div class="project-title-row">
      <span class="project-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24">
          <path d="M3 12.2 21 4l-5.8 16-3.6-6.6L3 12.2Z" />
          <path d="m11.6 13.4 4.8-5.1" />
        </svg>
      </span>
      <h3>{title}</h3>
    </div>
    <p>{description}</p>
    <ul class="tag-list" aria-label={`${title} tags`}>
      {tags.map((tag) => <li>{tag}</li>)}
    </ul>
    <div class="project-actions">
      {href && <a class="project-button project-button-primary" href={href} target="_blank" rel="noopener noreferrer">Live Demo</a>}
      {githubHref && <a class="project-button" href={githubHref} target="_blank" rel="noopener noreferrer">GitHub</a>}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    width: 100%;
    min-width: 0;
    gap: 18px;
    border: 1px solid #dbe3ef;
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(37, 99, 235, 0.045), transparent 42%),
      #fff;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
    padding: 2rem;
    white-space: normal;
    word-break: normal;
    overflow-wrap: normal;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .project-card:hover {
    border-color: rgba(37, 99, 235, 0.24);
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .project-preview {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 1px solid rgba(37, 99, 235, 0.14);
    border-radius: 18px;
    background: #0f172a;
  }

  .project-preview::after {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.18), transparent 44%);
    content: '';
    opacity: 0;
    transition: opacity 180ms ease;
  }

  .project-card:hover .project-preview::after {
    opacity: 1;
  }

  .project-preview img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .project-card:hover .project-preview img {
    transform: scale(1.035);
  }

  .project-year {
    display: inline-flex;
    width: fit-content;
    border: 1px solid rgba(37, 99, 235, 0.16);
    border-radius: 999px;
    background: var(--accent-soft);
    color: var(--accent-dark);
    padding: 4px 10px;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .project-body {
    display: grid;
    min-width: 0;
    align-content: start;
  }

  .project-title-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 10px;
    min-width: 0;
  }

  .project-icon {
    display: inline-grid;
    flex: 0 0 auto;
    width: 34px;
    height: 34px;
    place-items: center;
    border: 1px solid rgba(37, 99, 235, 0.18);
    border-radius: 12px;
    background: var(--accent-soft);
    color: var(--accent);
  }

  .project-icon svg {
    width: 18px;
    height: 18px;
  }

  .project-icon path {
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.8;
  }

  h3 {
    margin-bottom: 0;
    min-width: 0;
    font-size: clamp(1.25rem, 1.8vw, 1.55rem);
    font-weight: 720;
    letter-spacing: -0.02em;
    white-space: normal;
    word-break: normal;
    overflow-wrap: normal;
  }

  p {
    color: var(--muted);
    white-space: normal;
    word-break: normal;
    overflow-wrap: normal;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 18px 0 12px;
    padding: 0;
    list-style: none;
  }

  .tag-list li {
    color: #536170;
    font-size: 0.9rem;
  }

  .tag-list li::before {
    content: '#';
    color: var(--accent);
  }

  .project-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .project-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: #fff;
    color: var(--accent-dark);
    padding: 0 14px;
    font-size: 0.94rem;
    font-weight: 760;
    transition:
      transform 160ms ease,
      border-color 160ms ease,
      background 160ms ease,
      color 160ms ease;
  }

  .project-button:hover {
    border-color: var(--accent);
    background: var(--accent-soft);
    color: var(--accent-dark);
    text-decoration: none;
    transform: translateY(-1px);
  }

  .project-button-primary {
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
    box-shadow: 0 10px 22px rgba(37, 99, 235, 0.16);
  }

  .project-button-primary:hover {
    background: var(--accent-dark);
    color: #fff;
  }

  .project-card--card {
    min-height: 520px;
  }

  .project-card--card:hover {
    background:
      linear-gradient(180deg, rgba(37, 99, 235, 0.075), transparent 46%),
      var(--paper);
  }

  @media (max-width: 640px) {
    .project-card {
      padding: 1.5rem;
    }

    .project-card--card {
      min-height: auto;
    }
  }
</style>
