---
interface Point { label: string; detail?: string; lat: number; lon: number; color?: string; size?: number; }
interface Line { coordinates: [number, number][]; color?: string; }
interface Props { id: string; title: string; points: Point[]; lines?: Line[]; center?: [number,number]; zoom?: number; bounds?: [[number,number],[number,number]]; caption: string; source: string; fallback: string; height?: string; }
const { id, title, points, lines = [], center = [-98,38], zoom = 2.6, bounds, caption, source, fallback, height = '430px' } = Astro.props;
const config = encodeURIComponent(JSON.stringify({ points, lines, center, zoom, bounds }));
---
<figure class="wc-map-figure">
  <div class="wc-map-heading"><strong>{title}</strong><span>Interactive map</span></div>
  <div id={id} class="wc-map" data-world-cup-map data-config={config} style={`height:${height}`} aria-label={title}></div>
  <details class="wc-map-fallback" data-map-fallback hidden><summary>Text alternative</summary><p>{fallback}</p></details>
  <figcaption>{caption}<span>Source: {source}</span></figcaption>
</figure>
<script>
  import { initWorldCupMaps } from '../scripts/mapRuntime';
  const startMaps = () => {
    if (typeof window !== 'undefined') initWorldCupMaps();
  };
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', startMaps, { once: true });
  else startMaps();
</script>
<style>
  .wc-map-figure{margin:46px 0}.wc-map-heading{display:flex;justify-content:space-between;gap:16px;border:1px solid #d9dee7;border-bottom:0;border-radius:18px 18px 0 0;background:#172033;padding:13px 17px;color:#fff}.wc-map-heading span{color:#f6c76f;font-size:.72rem;font-weight:750;text-transform:uppercase}.wc-map{width:100%;height:55vh;min-height:420px;max-height:640px;border:1px solid #d9dee7;background:#e9eef4}.wc-map.map-unavailable::after{display:grid;height:100%;place-items:center;padding:20px;color:#64748b;content:'Interactive map unavailable. Use the text alternative below.'}.wc-map-fallback{border:1px solid #d9dee7;border-top:0;background:#fff;padding:9px 14px;color:#64748b;font-size:.78rem}.wc-map-fallback p{margin-top:8px!important;font-family:inherit!important;font-size:.8rem!important;line-height:1.5!important}.wc-map-figure figcaption{margin-top:12px;color:#6b7280;font-size:.8rem;line-height:1.55}.wc-map-figure figcaption span{display:block;margin-top:3px}@media(max-width:640px){.wc-map-heading{display:grid}.wc-map{height:55vh!important;min-height:420px}}
</style>
